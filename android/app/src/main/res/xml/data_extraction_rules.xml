<?xml version="1.0" encoding="utf-8"?>
<!--
  Excludes the ENTIRE app-data domain ("root" = everything) from both cloud backup and
  device-to-device transfer (Android 12+ "Copy your data" / D2D restore flow). Combined with
  android:allowBackup="false" in the manifest (which additionally blocks adb backup and legacy
  Auto Backup for Apps on older OS versions), this guarantees no sajalT app data is ever copied
  off the device through any Android-provided backup/transfer mechanism.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapability="true">
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
