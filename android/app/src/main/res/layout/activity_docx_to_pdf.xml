<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_variant">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_md"
        android:text="@string/feature_docx_to_pdf_title"
        android:textAppearance="@style/TextAppearance.SajalT.Title"
        android:textSize="20sp" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SajalT.CardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_md">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg"
            android:gravity="center">

            <TextView
                android:id="@+id/tvSelectedFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/status_idle"
                android:textAppearance="@style/TextAppearance.SajalT.Body"
                android:layout_marginBottom="@dimen/space_md" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectDocx"
                style="@style/Widget.SajalT.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_select_docx" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_md"
        android:visibility="gone"
        android:textSize="13sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_sm"
        android:text="@string/docxtopdf_limitations_note"
        android:textAppearance="@style/TextAppearance.SajalT.Body"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConvert"
        style="@style/Widget.SajalT.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_md"
        android:enabled="false"
        android:text="@string/btn_convert_to_pdf" />

</LinearLayout>
