<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SajalT" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/brand_primary</item>
        <item name="colorSecondaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnSecondary">@color/brand_on_primary</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/surface_variant</item>
        <item name="materialCardViewStyle">@style/Widget.SajalT.CardView</item>
    </style>

    <style name="Widget.SajalT.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.SajalT.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="backgroundTint">@color/brand_primary</item>
    </style>

    <style name="Widget.SajalT.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
    </style>

    <style name="Widget.SajalT.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/on_surface_muted</item>
    </style>

    <style name="TextAppearance.SajalT.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SajalT.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/on_surface_muted</item>
    </style>

</resources>
