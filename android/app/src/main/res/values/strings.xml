<resources>
    <string name="app_name">sajalT</string>
    <string name="home_subtitle">Offline document &amp; image converter</string>
    <string name="home_privacy_banner">100% offline. No internet permission. Your files never leave this device.</string>

    <!-- Feature cards -->
    <string name="feature_image_to_pdf_title">Image to PDF</string>
    <string name="feature_image_to_pdf_desc">Combine one or more photos into a single PDF, in the order you choose</string>
    <string name="feature_docx_to_pdf_title">DOCX to PDF</string>
    <string name="feature_docx_to_pdf_desc">Convert a Word document to PDF, entirely on-device</string>
    <string name="feature_pdf_to_docx_title">PDF to DOCX</string>
    <string name="feature_pdf_to_docx_desc">Convert a PDF into an editable Word document</string>
    <string name="feature_pdf_compress_title">Compress PDF</string>
    <string name="feature_pdf_compress_desc">Shrink a PDF to roughly the size you need</string>
    <string name="feature_image_compress_title">Compress Image</string>
    <string name="feature_image_compress_desc">Shrink a photo to roughly the size you need</string>
    <string name="feature_ocr_title">Offline Text Recognition (OCR)</string>
    <string name="feature_ocr_desc">Extract text from an image or scanned PDF page, fully on-device</string>

